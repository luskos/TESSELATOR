(* ===== CORRECTED MORT TESSELATOR SIMULATION ===== *)

(* Physical Parameters *)
c = 299792458; (* Exact speed of light *)
f = 300.0*10^9; (* 300 GHz *)
\[Lambda] = c/f; (* ~1.000 mm *)
k = 2 Pi/\[Lambda];
d = \[Lambda]/2; (* 0.5mm source spacing *)

(* Shield affects WAVES at shield position, not detector *)
shieldPhaseShift[xShield_, yShield_, pattern_] := Module[
  {r},
  r = Sqrt[xShield^2 + yShield^2];
  
  Switch[pattern,
    "XOR", If[r < \[Lambda]/4, Pi, 0], (* Central disk causes \[Pi] shift *)
    "AND", If[r < \[Lambda]/2, Pi/2, 0],
    "OR", If[xShield > 0, Pi, 0],
    "IDENTITY", 0,
    "NOT", If[xShield > 0, Pi, 0],
    _, 0
  ]
];

(* Correct wave propagation through shield *)
Tesselate[bitA_, bitB_, pattern_, detectorX_, detectorY_] := Module[
  {\[Phi]A, \[Phi]B, sourceA, sourceB, shieldX, shieldY, 
   rToShieldA, rToShieldB, rFromShieldToDetector,
   EAtShield, EBAtShield, EAfterShield, interference},
  
  (* Bit to phase conversion *)
  \[Phi]A = bitA * Pi;
  \[Phi]B = bitB * Pi;
  
  (* Path 1: Source A \[RightArrow] Shield (at position where wave hits) *)
  (* We need to integrate over all shield points, but simplify with center *)
  shieldX = 0; shieldY = 0; (* Center point of shield *)
  
  rToShieldA = Sqrt[(shieldX + d)^2 + shieldY^2];
  rToShieldB = Sqrt[(shieldX - d)^2 + shieldY^2];
  
  (* Field at shield from each source *)
  EAtShield = (1/(4 Pi rToShieldA)) * Exp[I (k rToShieldA + \[Phi]A)];
  EBAtShield = (1/(4 Pi rToShieldB)) * Exp[I (k rToShieldB + \[Phi]B)];
  
  (* Shield modifies the combined field *)
  EAfterShield = (EAtShield + EBAtShield) * 
                 Exp[I * shieldPhaseShift[shieldX, shieldY, pattern]];
  
  (* Path 2: Shield \[RightArrow] Detector *)
  rFromShieldToDetector = Sqrt[detectorX^2 + detectorY^2];
  
  (* Final field at detector *)
  interference = EAfterShield * (1/(4 Pi rFromShieldToDetector)) * 
                 Exp[I k rFromShieldToDetector];
  
  (* Return detected power *)
  Abs[interference]^2
];

(* ===== EMPIRICAL VALIDATION ===== *)
