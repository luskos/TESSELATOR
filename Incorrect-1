k = 2 Pi/\[Lambda];
d = \[Lambda]/2; (* 0.5mm - CRITICAL: Perfect interference distance *)

(* Reconfigurable Yin-Yang Shield with Multiple Geometries *)
shieldPhaseShift[x_, y_, pattern_] := Module[
  {centerX, centerY},
  centerX = 0; centerY = 0;
  
  Switch[pattern,
    "XOR", (* Central ridge causes \[Pi] shift only at exact center *)
    If[Abs[x - centerX] < \[Lambda]/10 && Abs[y - centerY] < \[Lambda]/10, Pi, 0],
    
    "AND", (* Valley creates \[Pi]/2 shift in larger region *)
    If[Sqrt[(x - centerX)^2 + (y - centerY)^2] < \[Lambda]/4, Pi/2, 0],
    
    "OR", (* Spiral creates position-dependent phase *)
    Mod[2 Pi * (x + y)/\[Lambda], 2 Pi],
    
    "IDENTITY", (* Flat - no phase shift *)
    0,
    
    "NOT", (* Inverting region *)
    If[x > 0, Pi, 0],
    
    _, 0 (* Default flat *)
  ]
];

(* Improved Tesselation with Distance-Attenuation *)
Tesselate[bitA_, bitB_, pattern_, x_, y_] := Module[
  {\[Phi]A, \[Phi]B, rA, rB, EA, EB, Eshield, attenuation},
  
  (* Convert bits to wave phase *)
  \[Phi]A = bitA * Pi;
  \[Phi]B = bitB * Pi;
  
  (* Physical distances with proper attenuation *)
  rA = Sqrt[(x + d)^2 + y^2 + (\[Lambda]/2)^2]; (* Added Z-distance for 3D *)
  rB = Sqrt[(x - d)^2 + y^2 + (\[Lambda]/2)^2];
  
  (* Free-space attenuation (1/r) *)
  EA = (1/(4 Pi rA)) * Exp[I (k rA + \[Phi]A)];
  EB = (1/(4 Pi rB)) * Exp[I (k rB + \[Phi]B)];
  
  (* Shield interaction *)
  Eshield = (EA + EB) * Exp[I * shieldPhaseShift[x, y, pattern]];
  
  (* Return detected power *)
  Abs[Eshield]^2
];

